{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=.;Initial Catalog=ChessTournaments;Integrated Security=True;TrustServerCertificate=True;"
  },
  "Identity": {
    "MaxFailedPasswordCount": 5,
    "DefaultLockoutTimeSpanInHours": 24
  },
  "Account": {
    "AllowRememberLogin": true,
    "RememberMeLoginDurationDays": 14
  },
  "Oidc": {
    "Issuer": "https://localhost:7225/",
    "AccessTokenLifetimeHours": 1,
    "RefreshTokenLifetimeHours": 720,
    "API": {
      "ClientId": "chess-tournaments_api",
      "ClientSecret": "846B62D0-DEF9-4215-A99D-86E6B8DAB342"
    },
    "SPA": {
      "ClientId": "chess-tournaments-spa",
      "DisplayName": "Angular client application",
      "LoginCallbackUris": [
        "https://localhost:4200/callback",
        "http://localhost:4200/callback"
      ],
      "LogoutCallbackUris": [
        "https://localhost:4200",
        "http://localhost:4200"
      ]
    },
    "CustomScopes": [
      {
        "Name": "crud_api",
        "DisplayName": "API access"
      }
    ]
  },
  "AppSettings": {
  },
  "ExternalLoginMicrosoft": {
    "Enabled": true,
    "ClientId": "*",
    "ClientSecret": "*",
    "TenantId": "*",
    "ClientIdsRequiringPrompt": []
  }
}

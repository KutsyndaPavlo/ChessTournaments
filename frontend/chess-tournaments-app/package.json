{
  "name": "chess-tournaments-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:local": "ng serve --configuration local",
    "start:staging": "ng serve --configuration staging",
    "start:prod": "ng serve --configuration production",
    "build": "ng build",
    "build:local": "ng build --configuration local",
    "build:staging": "ng build --configuration staging",
    "build:prod": "ng build --configuration production",
    "build:docker": "ng build --configuration docker",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "prettier:check": "prettier --check .",
    "prettier:format": "prettier --write .",
    "ng-openapi-gen": "npx -y ng-openapi-gen -c ./ng-openapi-gen-file.json"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.1",
  "dependencies": {
    "@angular/animations": "^21.0.6",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@ngxs/devtools-plugin": "20.1.0",
    "@ngxs/logger-plugin": "20.1.0",
    "@ngxs/storage-plugin": "20.1.0",
    "@ngxs/store": "^20.1.0",
    "@primeuix/themes": "^1.2.5",
    "angular-oauth2-oidc": "^20.0.2",
    "date-fns": "^4.1.0",
    "lucide-angular": "^0.548.0",
    "ng-openapi-gen": "^1.0.5",
    "primeicons": "^7.0.0",
    "primeng": "^20.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.0.3",
    "@angular/cli": "^21.0.3",
    "@angular/compiler-cli": "^21.0.0",
    "@eslint/js": "^9.39.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/jasmine": "~5.1.0",
    "angular-eslint": "20.5.0",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "jasmine-core": "~5.9.0",
    "jsdom": "^27.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.18",
    "tailwindcss-primeui": "^0.6.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.46.1",
    "vitest": "^4.0.8"
  }
}
